#!/usr/bin/env python3

import colorsys
import random
import subprocess
from pathlib import Path

from PIL import Image

WALLPAPER_DIR = Path.home() / "Pictures" / "wallpapers"
PROJECT_ROOT = Path.home() / "dotfiles_arch" / "quickshell" / "fortress"
QUICKSHELL_PALETTE = PROJECT_ROOT / "modules" / "Palette.qml"

IMAGE_EXTENSIONS = {".jpg", ".jpeg", ".png", ".webp", ".bmp"}


def clamp(value, minimum=0, maximum=255):
    return max(minimum, min(maximum, int(value)))


def rgb_to_hsv(rgb):
    r, g, b = [x / 255 for x in rgb]
    return colorsys.rgb_to_hsv(r, g, b)


def mix(a, b, amount):
    return tuple(clamp(a[i] * (1 - amount) + b[i] * amount) for i in range(3))


def lighten(rgb, amount):
    return mix(rgb, (255, 255, 255), amount)


def darken(rgb, amount):
    return mix(rgb, (0, 0, 0), amount)


def qrgba(rgb, alpha=1.0):
    r, g, b = rgb
    return f"Qt.rgba({r} / 255, {g} / 255, {b} / 255, {alpha})"


def find_wallpapers():
    return [p for p in WALLPAPER_DIR.rglob("*") if p.is_file() and p.suffix.lower() in IMAGE_EXTENSIONS]


def extract_palette(path):
    img = Image.open(path).convert("RGB")
    img.thumbnail((180, 180))

    paletted = img.quantize(colors=12, method=Image.Quantize.MEDIANCUT)
    palette = paletted.getpalette()
    counts = paletted.getcolors() or []

    colors = []
    for count, index in counts:
        rgb = (palette[index * 3], palette[index * 3 + 1], palette[index * 3 + 2])
        h, s, v = rgb_to_hsv(rgb)
        accent_score = count * (0.35 + s * 1.8) * (0.35 + v)
        bg_score = count * (1.4 - v) * (0.6 + s)
        colors.append({"rgb": rgb, "accent_score": accent_score, "bg_score": bg_score})

    if not colors:
        bg = (7, 16, 21)
        accent = (30, 175, 196)
    else:
        bg = max(colors, key=lambda c: c["bg_score"])["rgb"]
        accent = max(colors, key=lambda c: c["accent_score"])["rgb"]

    _, _, bg_v = rgb_to_hsv(bg)
    if bg_v > 0.35:
        bg = darken(bg, 0.65)

    _, accent_s, accent_v = rgb_to_hsv(accent)
    if accent_v < 0.45:
        accent = lighten(accent, 0.35)
    if accent_s < 0.18:
        accent = (30, 175, 196)

    return {
        "bg": bg,
        "panel": bg,
        "panelStrong": bg,
        "text": lighten(bg, 0.86),
        "textMuted": lighten(bg, 0.62),
        "accent": accent,
        "accentSoft": lighten(accent, 0.38),
        "muted": mix(bg, accent, 0.32),
        "hover": mix(bg, accent, 0.42),
        "border": mix(bg, accent, 0.55),
        "borderStrong": mix(bg, accent, 0.75),
        "danger": (215, 111, 74),
        "date": lighten(accent, 0.38),
    }


def write_palette(wallpaper, colors):
    QUICKSHELL_PALETTE.parent.mkdir(parents=True, exist_ok=True)
    content = f'''import QtQuick

QtObject {{
  property color bg: {qrgba(colors["bg"], 1.0)}
  property color panel: {qrgba(colors["panel"], 0.72)}
  property color panelStrong: {qrgba(colors["panelStrong"], 0.90)}

  property color text: {qrgba(colors["text"], 1.0)}
  property color textMuted: {qrgba(colors["textMuted"], 0.55)}

  property color accent: {qrgba(colors["accent"], 1.0)}
  property color accentSoft: {qrgba(colors["accentSoft"], 1.0)}

  property color muted: {qrgba(colors["muted"], 0.62)}
  property color hover: {qrgba(colors["hover"], 0.28)}
  property color border: {qrgba(colors["border"], 0.48)}
  property color borderStrong: {qrgba(colors["borderStrong"], 0.58)}
  property color danger: {qrgba(colors["danger"], 1.0)}
  property color date: {qrgba(colors["date"], 0.85)}

  property string wallpaper: "{str(wallpaper)}"
}}
'''
    QUICKSHELL_PALETTE.write_text(content)


def set_wallpaper(path):
    subprocess.run(["hyprctl", "hyprpaper", "reload", f",{path}"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def set_hyprland_border(colors):
    accent = colors["accent"]
    muted = colors["muted"]
    active = f"rgba({accent[0]:02x}{accent[1]:02x}{accent[2]:02x}dd)"
    inactive = f"rgba({muted[0]:02x}{muted[1]:02x}{muted[2]:02x}88)"
    subprocess.run(["hyprctl", "keyword", "general:col.active_border", active], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    subprocess.run(["hyprctl", "keyword", "general:col.inactive_border", inactive], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main():
    wallpapers = find_wallpapers()
    if not wallpapers:
        print(f"Keine Wallpaper gefunden in {WALLPAPER_DIR}")
        return

    wallpaper = random.choice(wallpapers)
    colors = extract_palette(wallpaper)
    write_palette(wallpaper, colors)
    set_wallpaper(wallpaper)
    set_hyprland_border(colors)

    print(f"Wallpaper: {wallpaper}")
    print(f"Accent:    {colors['accent']}")
    print(f"BG:        {colors['bg']}")


if __name__ == "__main__":
    main()
